{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "api-gateway",
  "sourceRoot": "api-gateway/src",
  "compilerOptions": {
    "tsConfigPath": "api-gateway/tsconfig.json",
    "webpack": false,
    "deleteOutDir": false
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "api-gateway",
      "entryFile": "main",
      "sourceRoot": "api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "api-gateway/tsconfig.json",
        "webpack": false,
        "deleteOutDir": false
      },
      "assets": [
        {
          "include": "../../lib/proto/*.proto",
          "outDir": "lib/proto",
          "watchAssets": true
        }
      ]
    },
    "auth-service": {
      "type": "application",
      "root": "auth-service",
      "entryFile": "main",
      "sourceRoot": "auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "auth-service/tsconfig.json",
        "webpack": false,
        "deleteOutDir": false
      },
      "assets": [
        {
          "include": "../../lib/proto/*.proto",
          "outDir": "lib/proto",
          "watchAssets": true
        }
      ]
    },
    "clinic-service": {
      "type": "application",
      "root": "clinic-service",
      "entryFile": "main",
      "sourceRoot": "clinic-service/src",
      "compilerOptions": {
        "tsConfigPath": "clinic-service/tsconfig.json",
        "webpack": false,
        "deleteOutDir": false
      },
      "assets": [
        {
          "include": "../../lib/proto/*.proto",
          "outDir": "lib/proto",
          "watchAssets": true
        }
      ]
    },
    "patient-service": {
      "type": "application",
      "root": "patient-service",
      "entryFile": "main",
      "sourceRoot": "patient-service/src",
      "compilerOptions": {
        "tsConfigPath": "patient-service/tsconfig.json",
        "webpack": false,
        "deleteOutDir": false
      },
      "assets": [
        {
          "include": "../../lib/proto/*.proto",
          "outDir": "lib/proto",
          "watchAssets": true
        }
      ]
    },
    "appointment-service": {
      "type": "application",
      "root": "appointment-service",
      "entryFile": "main",
      "sourceRoot": "appointment-service/src",
      "compilerOptions": {
        "tsConfigPath": "appointment-service/tsconfig.json",
        "webpack": false,
        "deleteOutDir": false
      },
      "assets": [
        {
          "include": "../../lib/proto/*.proto",
          "outDir": "lib/proto",
          "watchAssets": true
        }
      ]
    }
  }
}
