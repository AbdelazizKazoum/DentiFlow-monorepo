# Gateway port (set to 3001 to avoid conflict with frontend on 3000)
PORT=3001

# Frontend URL (used for CORS origin)
FRONTEND_URL=http://localhost:3000

# JWT signing secret — MUST match auth-service JWT_SECRET
JWT_SECRET=change-me-to-a-secure-random-string-of-at-least-32-characters

# JWT access token TTL in seconds (default: 900 = 15 min)
JWT_EXPIRES_IN=900

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Environment: development | production | test
NODE_ENV=development

# Downstream service base URLs (used in Story 8.5 gRPC wiring)
AUTH_SERVICE_URL=http://auth-service:3002
CLINIC_SERVICE_URL=http://clinic-service:3002

# gRPC URL for auth-service
AUTH_SERVICE_GRPC_URL=localhost:5001

# Notes:
# - When running inside Docker Compose, use the container DNS name:
#     AUTH_SERVICE_URL=http://auth-service:3002
# - When calling the auth service from your host (browser / curl), use:
#     http://localhost:3002
# - To override for local development (example):
#     export AUTH_SERVICE_URL=http://localhost:3002
#   or set in a .env.local file

