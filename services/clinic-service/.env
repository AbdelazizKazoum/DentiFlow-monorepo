# Clinic Service Environment Variables
# Copy this file to .env.local and fill in values for local development

# Server
PORT=3003
NODE_ENV=development

# gRPC
GRPC_PORT=5002

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_NAME=clinic_db

# Notes:
# - When running inside Docker Compose, the service should connect to the
#   `db` container: set `DB_HOST=db` (this is what docker-compose sets for containers).
