{
  "name": "dentiflow-services",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build api-gateway && nest build auth-service",
    "build:api-gateway": "nest build api-gateway",
    "build:auth-service": "nest build auth-service",
    "copy-proto:api-gateway": "node -e \"const f=require('fs');f.mkdirSync('api-gateway/dist/lib/proto',{recursive:true});f.copyFileSync('lib/proto/auth.proto','api-gateway/dist/lib/proto/auth.proto')\"",
    "copy-proto:auth-service": "node -e \"const f=require('fs');f.mkdirSync('auth-service/dist/lib/proto',{recursive:true});f.copyFileSync('lib/proto/auth.proto','auth-service/dist/lib/proto/auth.proto')\"",
    "prebuild:api-gateway": "pnpm run copy-proto:api-gateway",
    "prebuild:auth-service": "pnpm run copy-proto:auth-service",
    "prestart:api-gateway": "pnpm run copy-proto:api-gateway",
    "prestart:auth-service": "pnpm run copy-proto:auth-service",
    "prestart:dev:api-gateway": "pnpm run copy-proto:api-gateway",
    "prestart:dev:auth-service": "pnpm run copy-proto:auth-service",
    "start:api-gateway": "nest start api-gateway",
    "start:auth-service": "nest start auth-service",
    "start:dev:api-gateway": "nest start api-gateway --watch",
    "start:dev:auth-service": "nest start auth-service --watch",
    "start:debug:api-gateway": "nest start api-gateway --debug --watch",
    "start:debug:auth-service": "nest start auth-service --debug --watch",
    "test": "jest",
    "test:api-gateway": "jest --config api-gateway/jest.config.ts",
    "test:auth-service": "jest --config auth-service/jest.config.ts",
    "test:lib": "jest --config jest.config.ts",
    "test:watch:api-gateway": "jest --config api-gateway/jest.config.ts --watch",
    "test:watch:auth-service": "jest --config auth-service/jest.config.ts --watch",
    "test:cov:api-gateway": "jest --config api-gateway/jest.config.ts --coverage",
    "test:cov:auth-service": "jest --config auth-service/jest.config.ts --coverage",
    "migration:run": "ts-node --project auth-service/tsconfig.json -r tsconfig-paths/register node_modules/.bin/typeorm migration:run -d auth-service/src/infrastructure/persistence/data-source.ts",
    "migration:revert": "ts-node --project auth-service/tsconfig.json -r tsconfig-paths/register node_modules/.bin/typeorm migration:revert -d auth-service/src/infrastructure/persistence/data-source.ts",
    "migration:show": "ts-node --project auth-service/tsconfig.json -r tsconfig-paths/register node_modules/.bin/typeorm migration:show -d auth-service/src/infrastructure/persistence/data-source.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/microservices": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "joi": "^18.1.2",
    "mysql2": "^3.20.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.0"
  }
}
