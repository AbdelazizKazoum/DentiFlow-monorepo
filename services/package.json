{
  "name": "dentiflow-services",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "pnpm build:api-gateway && pnpm build:auth-service",
    "build:api-gateway": "tsc -p api-gateway/tsconfig.json",
    "build:auth-service": "tsc -p auth-service/tsconfig.json",
    "start:api-gateway": "node api-gateway/dist/api-gateway/src/main.js",
    "start:auth-service": "node auth-service/dist/auth-service/src/main.js",
    "start:dev:api-gateway": "cd api-gateway && ts-node --project tsconfig.json -r tsconfig-paths/register src/main.ts",
    "start:dev:auth-service": "cd auth-service && ts-node --project tsconfig.json -r tsconfig-paths/register src/main.ts",
    "test": "jest",
    "test:api-gateway": "jest --config api-gateway/jest.config.ts",
    "test:auth-service": "jest --config auth-service/jest.config.ts",
    "test:lib": "jest --config jest.config.ts",
    "test:watch:api-gateway": "jest --config api-gateway/jest.config.ts --watch",
    "test:watch:auth-service": "jest --config auth-service/jest.config.ts --watch",
    "test:cov:api-gateway": "jest --config api-gateway/jest.config.ts --coverage",
    "test:cov:auth-service": "jest --config auth-service/jest.config.ts --coverage",
    "migration:run": "ts-node --project auth-service/tsconfig.json -r tsconfig-paths/register node_modules/.bin/typeorm migration:run -d auth-service/src/infrastructure/persistence/data-source.ts",
    "migration:revert": "ts-node --project auth-service/tsconfig.json -r tsconfig-paths/register node_modules/.bin/typeorm migration:revert -d auth-service/src/infrastructure/persistence/data-source.ts",
    "migration:show": "ts-node --project auth-service/tsconfig.json -r tsconfig-paths/register node_modules/.bin/typeorm migration:show -d auth-service/src/infrastructure/persistence/data-source.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^18.1.2",
    "mysql2": "^3.20.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
