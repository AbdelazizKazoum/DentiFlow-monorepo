# Auth Service Environment Variables
# Copy this file to .env.local and fill in values for local development

# Server
PORT=3002
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_NAME=dentiflow_auth

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-of-at-least-32-characters
JWT_EXPIRES_IN=900

# Logging
LOG_LEVEL=info
