# Auth Service Environment Variables
# Copy this file to .env.local and fill in values for local development

# Server
PORT=3002
NODE_ENV=development

# gRPC
GRPC_PORT=5001

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_NAME=auth_db

# Notes:
# - When running inside Docker Compose, the service should connect to the
#   `db` container: set `DB_HOST=db` (this is what docker-compose sets for containers).
# - When running the service directly on your host (not in Docker), keep:
#     DB_HOST=localhost
# - When running the service directly on your host (not in Docker), keep:
#     DB_HOST=localhost
# - Example override for local host dev (bash):
#     export DB_HOST=localhost
#     export DB_PORT=3306
#     export DB_NAME=auth_db

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-of-at-least-32-characters
JWT_EXPIRES_IN=900

# Refresh Token
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=604800

# Logging
LOG_LEVEL=info
